{
  "name": "bowtie",
  "version": "2026.2.4",
  "description": "The UI displays the outcomes generated by Bowtie, which serves as a meta-validator for the JSON Schema specification",
  "repository": "github:bowtie-json-schema/bowtie",
  "license": "MIT",
  "author": {
    "name": "Julian Berman",
    "email": "Julian+Bowtie@GrayVines.com"
  },
  "keywords": [
    "jsonschema",
    "json schema",
    "json",
    "validation",
    "benchmarking",
    "apis",
    "api",
    "specifications"
  ],
  "type": "module",
  "engines": {
    "node": ">=21.0.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "start": "vite --no-clearScreen",
    "build": "tsc && vite build",
    "bundle-visualizer": "vite-bundle-visualizer",
    "preview": "vite preview",
    "lint": "eslint --max-warnings 0 src",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "vitest run; playwright test",
    "watch-test": "vitest watch"
  },
  "dependencies": {
    "@testing-library/react": "^16.3.2",
    "bootstrap": "^5.3.8",
    "dayjs": "^1.11.21",
    "mathjs": "^15.2.0",
    "react": "^19.2.6",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.16.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "title-case": "^4.3.2",
    "urijs": "^1.19.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/urijs": "^1.19.26",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "recharts": "3.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.8"
  }
}
